# ============================================================
# QueryVault — Root-level .env.example
# Copy relevant sections into query_manager/.env or etl_pipeline/.env
# ============================================================

# ---- Shared: PostgreSQL (source DB) --------------------------
# Used by query_manager (direct connection)
DATABASE_URL=postgresql://user:password@localhost:5433/queryValut

# Used by etl_pipeline (via Docker — host.docker.internal resolves to the host machine)
SOURCE_DB_URL=postgresql://user:password@host.docker.internal:5433/queryValut

# ---- Shared: ChromaDB ----------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=query_vault_queries

# ---- Shared: Embeddings --------------------------------------
EMBEDDING_PROVIDER=huggingface       # or: openai
EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENAI_API_KEY=

# ---- query_manager only --------------------------------------
LLM_PROVIDER=ollama                  # or: openai
LLM_MODEL=qwen:14b
OLLAMA_BASE_URL=http://localhost:11434
RAG_TOP_K=5

# ---- etl_pipeline only ---------------------------------------
ETL_DEFAULT_START_DATE=2020-01-01T00:00:00
UPSERT_BATCH_SIZE=100
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
