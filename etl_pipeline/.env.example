# Copy this file to .env and fill in the values before running docker-compose.

# ---- Source database (QueryVault app PostgreSQL) -------------------------
# Use host.docker.internal to reach a Postgres running on the Docker host
SOURCE_DB_URL=postgresql://<user>:<password>@host.docker.internal:5433/<dbname>

# ---- ChromaDB -----------------------------------------------------------
CHROMA_COLLECTION=query_vault_queries

# ---- Embedding -----------------------------------------------------------
# "huggingface" uses a local sentence-transformer model (no API key needed)
# "openai" uses text-embedding-ada-002 (requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2
OPENAI_API_KEY=

# ---- ETL behaviour -------------------------------------------------------
# ISO-8601 date used as the start of the very first full load
ETL_DEFAULT_START_DATE=2020-01-01T00:00:00
# Number of documents sent per ChromaDB upsert call
UPSERT_BATCH_SIZE=100

# ---- Airflow admin UI credentials ----------------------------------------
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
